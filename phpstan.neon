parameters:
    level: max
    paths:
        - includes/
    excludePaths:
        - includes/Test_Class.php (?)
    bootstrapFiles:
        - tests/bootstrap.php
    ignoreErrors:
        # WordPress functions and classes are mocked in bootstrap
        - '#Function register_rest_route not found#'
        - '#Function current_user_can not found#'
        - '#Function current_time not found#'
        - '#Class WP_REST_Controller not found#'
        - '#Class WP_REST_Request not found#'
        - '#Class WP_REST_Response not found#'
        - '#Class WP_Error not found#'
        - '#unknown class WP_REST_Controller#'
        - '#unknown class WP_REST_Request#'
        - '#invalid return type WP_REST_Response#'
        - '#invalid type WP_REST_Request#'
        - '#invalid return type WP_Error#'
        - '#Call to method .* on an unknown class WP_REST_Request#'
        - '#Instantiated class WP_REST_Response not found#'
        - '#Instantiated class WP_Error not found#'
        
        # Expected mixed types from WordPress REST API
        - '#Cannot cast mixed to int#'
        - '#Cannot cast mixed to float#'
        - '#Parameter .* expects string, mixed given#'
        
        # PromptBuilder API issues - need to check actual implementation
        - '#Call to an undefined static method WordPress\\AiClient\\Builders\\PromptBuilder::create#'
        - '#Cannot call method using.* on mixed#'
        - '#Method .* should return .* but returns mixed#'
        - '#Call to an undefined method .*::getModality#'
        - '#Call to an undefined method .*::getContent#'
        - '#Cannot access property \$value on mixed#'